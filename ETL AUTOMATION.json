    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction parseAIJson(raw) {\n  if (!raw) return null;\n\n  let text = String(raw).trim();\n\n  // Remove markdown code fences if AI returned ```json ... ```\n  text = text\n    .replace(/^```json/i, \"\")\n    .replace(/^```/i, \"\")\n    .replace(/```$/i, \"\")\n    .trim();\n\n  return JSON.parse(text);\n}\n\nfunction isValidEmail(email) {\n  return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\n}\n\nreturn items.map((item) => {\n  const parsed = parseAIJson(item.json.text);\n\n  const cleaned = {\n    Student_ID: parsed.Student_ID?.trim() || null,\n    Name: parsed.Name?.trim() || null,\n    Email: isValidEmail(parsed.Email) ? parsed.Email.trim().toLowerCase() : null,\n    Phone: String(parsed.Phone || \"\").replace(/\\D/g, \"\"),\n    Course: parsed.Course?.trim() || null,\n    Fee_Paid: Boolean(parsed.Fee_Paid),\n    City: parsed.City?.trim() || null,\n    Enrolled_Date: parsed.Enrolled_Date || null,\n\n    // optional validation flags\n    Email_Valid: isValidEmail(parsed.Email),\n    Phone_Valid: String(parsed.Phone || \"\").replace(/\\D/g, \"\").length === 10\n  };\n\n  return {\n    json: cleaned\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
