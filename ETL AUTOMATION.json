      "id": "8a923284-b232-4f80-a1c6-815abbfc9749",
      "name": "OpenAI Chat Model",
      "credentials": {
        "openAiApi": {
          "id": "UzXFPAYNQgYIuOxo",
          "name": "OpenAI account"
        }
      }
